# Configurações do Servidor
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Segurança - API Key para autenticação (obrigatório em produção)
# Gere uma chave segura: openssl rand -hex 32
API_KEY=sua-chave-api-secreta-aqui

# Configurações do Banco de Dados PostgreSQL
# Preferir DB_URL com host interno (rede privada) em produção.
# Exemplo com host interno (Docker/Swarm):
DB_URL=postgres://postgres:SENHA@pgbouncer_pgbouncer_transaction:5432/disparador_gupshup?sslmode=disable
# Alternativa: variáveis individuais (use host interno, não IP público)
# DB_HOST=pgbouncer_pgbouncer_transaction
# DB_NAME=disparador_gupshup
# DB_USER=postgres
# DB_PASSWORD=SENHA
# DB_PORT=5432
# Timeout de conexão com o banco (ms). Default: 15000. Aumente se a rede for lenta.
# DB_CONNECTION_TIMEOUT_MS=15000

